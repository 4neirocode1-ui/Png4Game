# Виртуальное окружение Python (тяжёлое, восстанавливается из зависимостей)
.venv/

# Кэш Python
__pycache__/
*.pyc

# Конфиг IDE
.idea/

# Сгенерированный результат нарезки (не исходник)
output/

# Личные сравнения/пробы пользователя
User_files/

# Локальные настройки (размер/формат) — у каждого свои
settings.json
